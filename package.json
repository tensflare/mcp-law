{
  "name": "@tensflare/mcp-law",
  "version": "0.1.0",
  "description": "Legal Tools for the Agentic Era — scaffolding and schemas for building jurisdiction-aware legal MCP servers",
  "type": "module",
  "bin": {
    "mcp-law": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tensflare/mcp-law.git"
  },
  "homepage": "https://github.com/tensflare/mcp-law#readme",
  "bugs": {
    "url": "https://github.com/tensflare/mcp-law/issues"
  },
  "keywords": ["mcp", "legal", "law", "model-context-protocol", "ai", "contracts", "jurisdiction"],
  "author": "Tensflare Inc.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
